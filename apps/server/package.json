{
  "name": "@codeplane/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "build": "bun build --minify src/index.ts --outfile dist/codeplane.js --target=bun --external cpu-features",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@codeplane/sdk": "workspace:*",
    "@codeplane-ai/workflow": "workspace:*",
    "hono": "latest",
    "ssh2": "latest"
  },
  "devDependencies": {
    "@types/ssh2": "latest"
  }
}
