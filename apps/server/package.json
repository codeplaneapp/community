{
  "name": "@codeplane/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "build": "bun build --minify src/index.ts --outfile dist/codeplane.js --target=bun --external cpu-features",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@codeplane/sdk": "workspace:*",
    "@codeplane-ai/workflow": "workspace:*",
    "better-result": "latest",
    "hono": "latest",
    "postgres": "latest",
    "ssh2": "latest"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ssh2": "latest",
    "bun-types": "^1.3.11",
    "typescript": "5.8.3"
  }
}
